# ─── Servidor ───────────────────────────────────────────
PORT=3000

# ─── Base de datos (SQLite integrado de Node) ───────────
# Ruta del archivo. En EasyPanel apunta a un volumen persistente, ej. /app/data/wolf.db
SQLITE_PATH=./data/wolf.db

# ─── OpenAI ─────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Modelo de transcripción de notas de voz (opcional, por defecto whisper-1)
OPENAI_TRANSCRIBE_MODEL=whisper-1

# ─── YCloud (WhatsApp) ──────────────────────────────────
YCLOUD_API_KEY=
YCLOUD_PHONE_NUMBER=
# Secreto compartido para validar que el webhook viene de YCloud
YCLOUD_WEBHOOK_SECRET=

# ─── Google Drive (CV de los aptos) — OAuth ─────────────
# Cliente OAuth (Google Cloud Console) + refresh token (OAuth Playground).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Carpeta "Aptos" de Drive donde se guardan los CV.
DRIVE_FOLDER_ID=
