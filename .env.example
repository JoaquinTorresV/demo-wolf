# ─── Servidor ───────────────────────────────────────────
PORT=3000

# ─── Base de datos (SQLite integrado de Node) ───────────
# Ruta del archivo. En EasyPanel apunta a un volumen persistente, ej. /app/data/wolf.db
SQLITE_PATH=./data/wolf.db

# ─── OpenAI ─────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# ─── YCloud (WhatsApp) ──────────────────────────────────
YCLOUD_API_KEY=
YCLOUD_PHONE_NUMBER=
# Secreto compartido para validar que el webhook viene de YCloud
YCLOUD_WEBHOOK_SECRET=

# ─── Google Drive (CV de los aptos) ─────────────────────
# JSON completo de la cuenta de servicio, en base64 (igual que en el bot de Diego).
GOOGLE_SERVICE_ACCOUNT_B64=
# Carpeta "Aptos" de Drive donde se guardan los CV.
DRIVE_FOLDER_ID=10uwV8uCmAY4GZ9y4m3T4ly1vWPtMY82D
