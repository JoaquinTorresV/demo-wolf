{
  "name": "wolf-control-bot",
  "version": "0.1.0",
  "description": "Bot de WhatsApp para filtrar candidatos de Wolf Control (seguridad, Cataluña). YCloud + OpenAI + SQLite.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node --experimental-sqlite src/index.js",
    "dev": "node --experimental-sqlite --watch src/index.js",
    "migrate": "node --experimental-sqlite src/db/migrate.js",
    "test": "node src/services/bot/filters.test.js",
    "simular": "node --experimental-sqlite scripts/simular.js",
    "probar": "node --experimental-sqlite scripts/probar.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "openai": "^6.2.0"
  }
}
